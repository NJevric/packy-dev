{
  "name": "packy",
  "version": "0.1.0",
  "description": "Modern UI for managing npm dependencies and packages",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "packy": "dist/bin/packy.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsup src/server/index.ts src/bin/packy.ts --format esm --dts --outDir dist",
    "preview": "npm run build && node dist/bin/packy.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .vue,.ts",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "npm",
    "package-manager",
    "ui",
    "dashboard",
    "dependencies",
    "vue",
    "vite"
  ],
  "author": "Nikola Jevric",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikolajevric/packy.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "open": "^10.1.0",
    "semver": "^7.6.3",
    "get-port": "^7.1.0"
  },
  "devDependencies": {
    "@tanstack/vue-query": "^5.62.9",
    "@vueuse/core": "^12.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "lucide-vue-next": "^0.469.0",
    "pinia": "^2.3.0",
    "postcss": "^8.4.49",
    "radix-vue": "^1.9.11",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  }
}
